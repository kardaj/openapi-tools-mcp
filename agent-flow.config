[project]
name = "openapi-tools-mcp"
flavor = "python-lib"

[workflow]
single_current_change = true
briefs_dir = "changes/briefs"
current_dir = "changes/current"
done_dir = "changes/done"
sequence_digits = 4
start_launches_agent = true
workbook_required_for_managed_changes = true
workbook_required_for_ad_hoc_tasks = false

[archive]
include = ["CHANGE.md", "SUMMARY.md", "artifacts/**"]
include_if_exists = ["WORKBOOK.md"]
exclude = ["notes/tmp/**", "logs/raw/**", "*.scratch.md"]

[brief_review]
prompt_path = "prompts/agent-flow-review-brief.md"

[review]
[review.diff]
base_branch = "develop"
prompt_path = "prompts/agent-flow-review.md"

[quality_gate]
review_agent_model = "gpt-5.5"
review_agent_reasoning_effort = "high"
mode = "diff-review"
on_unavailable = "block"

[surfaces]
enabled = ["public_api", "packaging", "configuration", "observability", "tests"]

[surfaces.catalog]
[surfaces.catalog.ui]
label = "UI"
aliases = ["screens", "views", "components"]

[surfaces.catalog.navigation]
label = "Navigation"
aliases = ["routing", "flow", "screen flow"]

[surfaces.catalog.persistence]
label = "Persistence"
aliases = ["database", "schema", "migrations", "storage"]

[surfaces.catalog.api]
label = "API contracts"
aliases = ["network calls", "api shape", "http endpoints"]

[surfaces.catalog.background_jobs]
label = "Background jobs"
aliases = ["background tasks", "celery", "task orchestration", "task-orchestration"]

[surfaces.catalog.notifications]
label = "Notifications"
aliases = ["push notifications", "local notifications"]

[surfaces.catalog.analytics]
label = "Analytics"
aliases = ["events", "metrics"]

[surfaces.catalog.auth]
label = "Auth"
aliases = ["authentication", "authorization", "permissions"]

[surfaces.catalog.observability]
label = "Observability"
aliases = ["logging", "metrics", "tracing", "alerts"]

[surfaces.catalog.configuration]
label = "Configuration"
aliases = ["settings", "environment", "feature flags"]

[surfaces.catalog.public_api]
label = "Public API"
aliases = ["library api", "exported api", "backward compatibility"]

[surfaces.catalog.packaging]
label = "Packaging"
aliases = ["distribution", "versioning", "dependencies"]

[surfaces.catalog.accessibility]
label = "Accessibility"
aliases = ["a11y", "screen readers", "keyboard navigation"]

[surfaces.catalog.localization]
label = "Localization"
aliases = ["i18n", "translations", "locale behavior"]

[surfaces.catalog.offline_behavior]
label = "Offline behavior"
aliases = ["offline", "sync", "cache behavior"]

[surfaces.catalog.permissions]
label = "Permissions"
aliases = ["entitlements", "access control", "capabilities"]

[surfaces.catalog.state_ownership]
label = "State ownership"
aliases = ["state flow", "view model state", "client state"]

[surfaces.catalog.external_integrations]
label = "External integrations"
aliases = ["third-party services", "webhooks", "external APIs"]

[surfaces.catalog.tests]
label = "Tests"
aliases = ["test expectations", "test coverage", "verification"]

[templates]
engine = "jinja"
prompt_profile = "behavior-first"
rendered_prompts_dir = "prompts"
prompt_prefix = "agent-flow-"

[instructions]
update_agents_md = true
agents_md_path = "AGENTS.md"
implementation_prompt_path = "prompts/agent-flow-implement.md"

[adapters]
[adapters.codex]
enabled = true
command = "codex"
args = []
mode = "interactive"
start_mode = "implement"
skill_dir = ".agents/skills/agent-flow"
install_global_prompts = false
global_prompts_dir = "~/.codex/prompts"

[adapters.claude]
enabled = false
command = "claude"
args = []
commands_dir = ".claude/commands"

[git]
enabled = true
trunk_branch = "develop"
branch_prefix = "change/"
create_branch_on_start = true
merge_on_finish = true

[canonical_docs]
[canonical_docs.architecture]
paths = ["ARCHITECTURE.md"]
inject_into = ["clarify", "implement", "review"]
optional = true

[canonical_docs.behaviors]
paths = ["docs/behaviors.md"]
inject_into = ["clarify", "implement", "review"]
optional = true

[canonical_docs.testing]
paths = ["docs/testing.md"]
inject_into = ["clarify", "implement", "review"]
optional = true
